generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentSource {
  MANUAL
  ONLINE_BOOKING
}

enum ReminderStatus {
  NONE
  PENDING
  SENT
  FAILED
}

enum ReminderChannel {
  WHATSAPP
  SMS
  EMAIL
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business Business?

  @@map("users")
}

model Business {
  id                  String   @id @default(cuid())
  ownerId             String   @unique
  name                String
  slug                String   @unique
  phone               String?
  address             String?
  slotIntervalMinutes Int      @default(30)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  owner        User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workingHours WorkingHours[]
  clients      Client[]
  services     Service[]
  appointments Appointment[]
  reminderLogs ReminderLog[]

  @@map("businesses")
}

model WorkingHours {
  id         String  @id @default(cuid())
  businessId String
  dayOfWeek  Int     // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  startTime  String  // "09:00" (HH:mm)
  endTime    String  // "19:00" (HH:mm)
  isOpen     Boolean @default(true)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
  @@map("working_hours")
}

model Client {
  id                String    @id @default(cuid())
  businessId        String
  name              String
  phone             String
  email             String?
  notes             String?
  lastAppointmentAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([businessId, phone])
  @@index([businessId])
  @@index([name])
  @@map("clients")
}

model Service {
  id              String   @id @default(cuid())
  businessId      String
  name            String
  durationMinutes Int
  price           Decimal? @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([businessId])
  @@map("services")
}

model Appointment {
  id              String            @id @default(cuid())
  businessId      String
  clientId        String
  serviceId       String
  appointmentDate DateTime          @db.Date
  startTime       String            // "09:00" (HH:mm)
  endTime         String            // "09:30" (HH:mm)
  status          AppointmentStatus @default(PENDING)
  source          AppointmentSource @default(MANUAL)
  notes           String?
  noShow          Boolean           @default(false)
  reminderStatus  ReminderStatus    @default(NONE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  reminderLogs ReminderLog[]

  @@index([businessId, appointmentDate])
  @@index([businessId, status])
  @@index([clientId])
  @@map("appointments")
}

model ReminderLog {
  id            String          @id @default(cuid())
  businessId    String
  appointmentId String
  channel       ReminderChannel
  status        ReminderStatus
  recipient     String          // phone number or email
  message       String?
  sentAt        DateTime?
  error         String?
  createdAt     DateTime        @default(now())

  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([businessId])
  @@map("reminder_logs")
}
